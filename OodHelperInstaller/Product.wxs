<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <!-- Version is not hardwired: it is read from the built OodHelper.dll's assembly version and passed
       in as the AppVersion preprocessor variable by OodHelperInstaller.wixproj. -->
  <Package Name="OodHelper" Language="1033" Version="$(var.AppVersion)" Manufacturer="David Woakes" UpgradeCode="{586CAE3C-1E00-4522-ABD5-DFEAE4C5DA54}" InstallerVersion="200">

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="OodHelperInstaller" Level="1">
      <!-- Files (the application plus its full dependency closure) are harvested from the app build
           output at build time into ProductComponents; see OodHelperInstaller.wixproj. -->
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="ApplicationShortcuts" />
      <ComponentRef Id="CleanupInstallFolder" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="OodHelper" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder" />
    <StandardDirectory Id="DesktopFolder" />
  </Fragment>

  <Fragment>
    <!-- Start-menu and desktop shortcuts to the harvested executable. Non-advertised shortcuts can
         target the installed file by path, so they do not need to live in the file's (harvested)
         component; a per-user registry value provides the component key path. -->
    <Component Id="ApplicationShortcuts" Directory="INSTALLFOLDER" Guid="{B8F9A1C2-7E54-4D3A-9C61-2A6F0D4E1B77}">
      <Shortcut Id="StartMenuOodHelper" Directory="ProgramMenuFolder" Name="OodHelper"
                Target="[INSTALLFOLDER]OodHelper.exe" WorkingDirectory="INSTALLFOLDER" />
      <Shortcut Id="DesktopOodHelper" Directory="DesktopFolder" Name="OodHelper"
                Target="[INSTALLFOLDER]OodHelper.exe" WorkingDirectory="INSTALLFOLDER" />
      <RegistryValue Root="HKCU" Key="Software\David Woakes\OodHelper" Name="installed"
                     Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <!-- Remove the (now empty) install folder on uninstall, since the harvested file components do
         not author the root directory (SuppressRootDirectory). -->
    <Component Id="CleanupInstallFolder" Directory="INSTALLFOLDER" Guid="{AA426A21-58BC-4DE5-89F7-21FC16A1CE11}">
      <RemoveFolder Id="RemoveInstallFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\David Woakes\OodHelper" Name="folder"
                     Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Fragment>
</Wix>
