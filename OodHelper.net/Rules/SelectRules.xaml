<Window x:Class="OodHelper.Rules.SelectRules"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Icon="/OodHelper;component/Images/Boat.png" Title="Select Rules"
        Loaded="Window_Loaded" ShowInTaskbar="False" KeyUp="Window_KeyUp"
        FocusManager.FocusedElement="{Binding ElementName=Filter}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ToolBarTray>
            <ToolBar>
                <Button Name="Add" Command="{Binding AddCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Grid.Column="0" Source="/OodHelper;component/Images/Add.png" />
                        <Label Grid.Column="1">Add</Label>
                    </StackPanel>
                </Button>
                <Button Name="Edit" Command="{Binding EditCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Grid.Column="0" Source="/OodHelper;component/Images/Edit.png" />
                        <Label Grid.Column="1">Edit</Label>
                    </StackPanel>
                </Button>
                <Button Name="Delete" Command="{Binding DeleteCommand}"
                        CommandParameter="{Binding SelectedItems, ElementName=RuleData}">
                    <StackPanel Orientation="Horizontal">
                        <Image Grid.Column="0" Source="/OodHelper;component/Images/Delete.png" />
                        <Label Grid.Column="1">Delete</Label>
                    </StackPanel>
                </Button>
                <Button Name="CloseButton" Click="Close_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Grid.Column="0" Source="/OodHelper;component/Images/Cancel.png" />
                        <Label Grid.Column="1">Close</Label>
                    </StackPanel>
                </Button>
            </ToolBar>
        </ToolBarTray>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2">
            <Label Margin="3,0">Find</Label>
            <TextBox Name="Filter" Margin="2" Width="250" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock VerticalAlignment="Center" Margin="4,0">Press F3 to search</TextBlock>
        </StackPanel>
        <DockPanel Grid.Row="2" >
            <DataGrid Name="RuleData" IsReadOnly="True"
                      ItemsSource="{Binding Rows}"
                      SelectedItem="{Binding SelectedRow}">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Edit" Command="{Binding EditCommand}">
                            <MenuItem.Icon>
                                <Image Source="/OodHelper;component/Images/Edit.png" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Delete" Command="{Binding DeleteCommand}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <Image Source="/OodHelper;component/Images/Delete.png" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </DockPanel>
    </Grid>
</Window>
