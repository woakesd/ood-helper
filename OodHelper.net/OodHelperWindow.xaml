<Window x:Class="OodHelper.OodHelperWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="OodHelper" WindowState="Maximized"
        Loaded="Window_Loaded"
        BorderThickness="0" mc:Ignorable="d" d:DesignHeight="300" d:DesignWidth="731">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition />
        </Grid.RowDefinitions>
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="E_xit" Name="Exit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Boats" Name="Boats" Command="{Binding OpenBoatsCommand}">
                    <MenuItem.Icon>
                        <Image Width="16" Height="16" Margin="1" Source="/OodHelper;component/Images/Boat-16.png" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Calendar" Name="Calendar" Command="{Binding OpenCalendarCommand}" Visibility="{Binding Path=ShowPrivilegedItems,Converter={StaticResource ResourceKey=BooleanToVisibilityConverter}}">
                    <MenuItem.Icon>
                        <Image Width="16" Height="16" Margin="1" Source="/OodHelper;component/Images/Calendar-16.png" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Series" Command="{Binding OpenSeriesCommand}" Visibility="{Binding Path=ShowPrivilegedItems,Converter={StaticResource ResourceKey=BooleanToVisibilityConverter}}">
                </MenuItem>
                <MenuItem Header="_Handicaps" Command="{Binding OpenHandicapsCommand}" Visibility="{Binding Path=ShowPrivilegedItems,Converter={StaticResource ResourceKey=BooleanToVisibilityConverter}}">
                    <MenuItem.Icon>
                        <Image Width="16" Height="16" Margin="1" Source="/OodHelper;component/Images/Hand-16.png" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Rule" Command="{Binding OpenRulesCommand}" Visibility="{Binding Path=ShowPrivilegedItems,Converter={StaticResource ResourceKey=BooleanToVisibilityConverter}}" />
            </MenuItem>
            <MenuItem Header="_Admin">
                <MenuItem Header="Tide" Name="Tide" Command="{Binding OpenTideCommand}" Visibility="{Binding Path=ShowPrivilegedItems,Converter={StaticResource ResourceKey=BooleanToVisibilityConverter}}" />
                <MenuItem Header="Sun" Name="Sun" Command="{Binding OpenSunCommand}" />
                <MenuItem Header="_Configuration" Name="Configuration" Command="{Binding OpenConfigurationCommand}" Visibility="{Binding Path=ShowPrivilegedItems,Converter={StaticResource ResourceKey=BooleanToVisibilityConverter}}">
                    <MenuItem.Icon>
                        <Image Width="16" Height="16" Margin="1" Source="/OodHelper;component/Images/Spanner-16.png" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Create Results DB" Name="CreateResultsDB" Command="{Binding RecreateDbCommand}" Visibility="{Binding Path=ShowPrivilegedItems,Converter={StaticResource ResourceKey=BooleanToVisibilityConverter}}">
                    <MenuItem.Icon>
                        <Image Source="/OodHelper;component/Images/Database-16.png" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Import _PY" Name="importPY" Command="{Binding ImportPyCommand}"  Visibility="{Binding Path=ShowPrivilegedItems,Converter={StaticResource ResourceKey=BooleanToVisibilityConverter}}"/>
                <MenuItem Header="_Export Results" Name="ExportResults" Command="{Binding ExportResultsCommand}" Visibility="{Binding Path=ShowPrivilegedItems,Converter={StaticResource ResourceKey=BooleanToVisibilityConverter}}"/>
                <MenuItem Header="Logout" Name="Logout" Visibility="{Binding Path=ShowPrivilegedItems,Converter={StaticResource ResourceKey=BooleanToVisibilityConverter}}" Command="{Binding LogoutCommand}">
                    <MenuItem.Icon>
                        <Image Source="/OodHelper;component/Images/Lock-Open-16.png" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Login" Name="Login" Visibility="{Binding Path=HideNonPrivilegedItems,Converter={StaticResource ResourceKey=BooleanToVisibilityConverter}}" Command="{Binding LoginCommand}">
                    <MenuItem.Icon>
                        <Image Source="/OodHelper;component/Images/Lock-16.png" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Command="{Binding ShowAboutCommand}" >
                    <MenuItem.Icon>
                        <Image Source="/OodHelper;component/Images/Info-16.png" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>
        <ToolBarTray Name="mainToolbarTray" VerticalAlignment="Top" Grid.Row="1">
            <ToolBar Name="mainToolbar" VerticalAlignment="Top">
                <Button Name="Download" Command="{Binding DownloadCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/OodHelper;component/Images/Download.png"/>
                        <Label>Download from Web</Label>
                    </StackPanel>
                </Button>
                <Button Name="Results" Command="{Binding ShowRaceResultsCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/OodHelper;component/Images/Results.png"/>
                        <Label>Results</Label>
                    </StackPanel>
                </Button>
                <Button Name="SeriesResults" Command="{Binding ShowSeriesResultsCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/OodHelper;component/Images/Results.png"/>
                        <Label>Series Results</Label>
                    </StackPanel>
                </Button>
                <Button Name="Upload" Command="{Binding UploadCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/OodHelper;component/Images/Upload.png" />
                        <Label>Upload to Web</Label>
                    </StackPanel>
                </Button>
                <Button Name="EntrySheets" Command="{Binding OpenEntrySheetsCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/OodHelper;component/Images/Applications.png"/>
                        <Label>Entry Sheets</Label>
                    </StackPanel>
                </Button>
            </ToolBar>
        </ToolBarTray>
        <TabControl Grid.Row="2" Name="dock"/>
    </Grid>
</Window>
