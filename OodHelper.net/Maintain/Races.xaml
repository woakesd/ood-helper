<Window x:Class="OodHelper.Maintain.Races"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Icon="/OodHelper;component/Images/Calendar.png" Title="Races"
        Loaded="Window_Loaded" ShowInTaskbar="False" KeyUp="Window_KeyUp">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ToolBarTray>
            <ToolBar>
                <Button Name="Add" Command="{Binding AddCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/OodHelper;component/Images/Add.png" />
                        <Label>_Add</Label>
                    </StackPanel>
                </Button>
                <Button Name="Edit" Command="{Binding EditCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/OodHelper;component/Images/Edit.png" />
                        <Label>_Edit</Label>
                    </StackPanel>
                </Button>
                <Button Name="Delete" Command="{Binding DeleteCommand}"
                        CommandParameter="{Binding SelectedItems, ElementName=RaceData}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/OodHelper;component/Images/Delete.png" />
                        <Label >_Delete</Label>
                    </StackPanel>
                </Button>
                <Button Name="CloseButton" Click="CloseButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/OodHelper;component/Images/Cancel.png" />
                        <Label>Close</Label>
                    </StackPanel>
                </Button>
            </ToolBar>
        </ToolBarTray>
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,2" >
            <Label Margin="3,0">Find</Label>
            <TextBox Name="Eventname" Margin="2" Width="250" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock VerticalAlignment="Center" Margin="4,0">Press F3 to search</TextBlock>
        </StackPanel>
        <DockPanel Grid.Row="2" >
            <DataGrid Name="RaceData" IsReadOnly="True" AutoGenerateColumns="False"
                      ItemsSource="{Binding Rows}"
                      SelectedItem="{Binding SelectedRow}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date" Binding="{Binding StartDate, StringFormat='dd MMM yyyy HH:mm'}" />
                    <DataGridTextColumn Header="Event" Binding="{Binding Event}" Width="*" />
                    <DataGridTextColumn Header="Class" Binding="{Binding Class}" />
                    <DataGridTextColumn Header="Course" Binding="{Binding Course}" />
                    <DataGridTextColumn Header="OOD" Binding="{Binding Ood}" />
                    <DataGridTextColumn Header="Venue" Binding="{Binding Venue}" />
                    <DataGridTextColumn Header="Flag" Binding="{Binding Flag}" />
                    <DataGridTextColumn Header="Race Type" Binding="{Binding Racetype}" />
                    <DataGridCheckBoxColumn Header="Is Race" Binding="{Binding IsRace}" />
                    <DataGridCheckBoxColumn Header="Raced" Binding="{Binding Raced}" />
                    <DataGridCheckBoxColumn Header="Approved" Binding="{Binding Approved}" />
                </DataGrid.Columns>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Edit" Command="{Binding EditCommand}">
                            <MenuItem.Icon>
                                <Image Source="/OodHelper;component/Images/Edit.png" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Delete" Command="{Binding DeleteCommand}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                            <MenuItem.Icon>
                                <Image Source="/OodHelper;component/Images/Delete.png" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </DockPanel>
    </Grid>
</Window>
